}

@article{funke_placing_2016,
  title = {Placing Molecules with {{Bohr}} Radius Resolution Using {{DNA}} Origami},
  author = {Funke, Jonas J. and Dietz, Hendrik},
  date = {2016-01},
  journaltitle = {Nature Nanotechnology},
  shortjournal = {Nat Nano},
