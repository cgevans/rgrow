@article{wood_asynuclein_1999,
  title = {α-{{Synuclein Fibrillogenesis Is Nucleation-dependent IMPLICATIONS FOR THE PATHOGENESIS OF PARKINSON}}′{{S DISEASE}}},
  author = {Wood, Stephen J. and Wypych, Jette and Steavenson, Shirley and Louis, Jean-Claude and Citron, Martin and Biere, Anja Leona},
