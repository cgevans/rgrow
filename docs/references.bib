@article{owczarzy_predicting_2008,
  title = {Predicting {{Stability}} of {{DNA Duplexes}} in {{Solutions Containing Magnesium}} and {{Monovalent Cations}}},
  author = {Owczarzy, Richard and Moreira, Bernardo G. and You, Yong and Behlke, Mark A. and Walder, Joseph A.},
