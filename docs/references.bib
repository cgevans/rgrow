  author = {Biffi, Silvia and Cerbino, Roberto and Bomboi, Francesca and Paraboschi, Elvezia Maria and Asselta, Rosanna and Sciortino, Francesco and Bellini, Tommaso},
  date = {2013-09-24},
  journaltitle = {Proceedings of the National Academy of Sciences},
  shortjournal = {Proc. Natl. Acad. Sci. U.S.A.},
