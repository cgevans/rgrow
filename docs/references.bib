@article{nath_early_2010,
  title = {Early {{Aggregation Steps}} in α-{{Synuclein}} as {{Measured}} by {{FCS}} and {{FRET}}: {{Evidence}} for a {{Contagious Conformational Change}}},
  shorttitle = {Early {{Aggregation Steps}} in α-{{Synuclein}} as {{Measured}} by {{FCS}} and {{FRET}}},
  author = {Nath, Sangeeta and Meuvis, Jessika and Hendrix, Jelle and Carl, Shaun A. and Engelborghs, Yves},
  date = {2010-04-07},
  journaltitle = {Biophysical Journal},
  shortjournal = {Biophys J},
  volume = {98},
