  author = {Adam, Sabrina and Klingel, Viviane and Radde, Nicole E and Bashtrykov, Pavel and Jeltsch, Albert},
  date = {2023-07-21},
  journaltitle = {Nucleic Acids Research},
  shortjournal = {Nucleic Acids Research},
  volume = {51},
