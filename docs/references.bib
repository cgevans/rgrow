@article{xia_thermodynamic_1998,
  title = {Thermodynamic {{Parameters}} for an {{Expanded Nearest-Neighbor Model}} for {{Formation}} of {{RNA Duplexes}} with {{Watson}}−{{Crick Base Pairs}}},
  author = {Xia, Tianbing and SantaLucia, John Jr. and Burkard, Mark E. and Kierzek, Ryszard and Schroeder, Susan J. and Jiao, Xiaoqi and Cox, Christopher and Turner, Douglas H.},
  date = {1998-10-01},
