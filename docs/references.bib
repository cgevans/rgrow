@article{bergeron_reverse_2012,
  title = {Reverse {{Genetics Recovery}} of {{Lujo Virus}} and {{Role}} of {{Virus RNA Secondary Structures}} in {{Efficient Virus Growth}}},
  author = {Bergeron, Éric and Chakrabarti, Ayan K. and Bird, Brian H. and Dodd, Kim A. and McMullan, Laura K. and Spiropoulou, Christina F. and Nichol, Stuart T. and Albariño, César G.},
