@article{sajfutdinow_direct_2018,
  title = {Direct Observation and Rational Design of Nucleation Behavior in Addressable Self-Assembly},
  author = {Sajfutdinow, Martin and Jacobs, William M. and Reinhardt, Aleks and Schneider, Christoph and Smith, David M.},
  date = {2018-06-26},
  journaltitle = {Proceedings of the National Academy of Sciences},
  volume = {115},
