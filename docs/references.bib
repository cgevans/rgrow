@article{bolhuis_transition_2021,
  title = {Transition {{Path Sampling}} as {{Markov Chain Monte Carlo}} of {{Trajectories}}: {{Recent Algorithms}}, {{Software}}, {{Applications}}, and {{Future Outlook}}},
