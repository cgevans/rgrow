@article{jucker_pathogenic_2011,
  title = {Pathogenic Protein Seeding in Alzheimer Disease and Other Neurodegenerative Disorders},
  author = {Jucker, Mathias and Walker, Lary C.},
  date = {2011-10-01},
  journaltitle = {Annals of Neurology},
  shortjournal = {Ann Neurol.},
