@article{schulman_increasing_2015,
  title = {Increasing {{Redundancy Exponentially Reduces Error Rates}} during {{Algorithmic Self-Assembly}}},
  author = {Schulman, Rebecca and Wright, Christina and Winfree, Erik},
  date = {2015-06-23},
  journaltitle = {ACS Nano},
  shortjournal = {ACS Nano},
  volume = {9},
  number = {6},
