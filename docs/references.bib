@inproceedings{shalaby_minimum_2023,
  title = {Minimum {{Free Energy}}, {{Partition Function}} and {{Kinetics Simulation Algorithms}} for a {{Multistranded Scaffolded DNA Computer}}},
  booktitle = {{{DNA}} 29},
  author = {Shalaby, Ahmed and Thachuk, Chris and Woods, Damien},
  date = {2023},
  publisher = {Schloss Dagstuhl – Leibniz-Zentrum für Informatik},
  doi = {10.4230/LIPIcs.DNA.29.1},
  url = {https://drops.dagstuhl.de/entities/document/10.4230/LIPIcs.DNA.29.1},
  urldate = {2024-07-22},
  abstract = {Polynomial time dynamic programming algorithms play a crucial role in the design, analysis and engineering of nucleic acid systems including DNA computers and DNA/RNA nanostructures. However, in complex multistranded or pseudoknotted systems, computing the minimum free energy (MFE), and partition function of nucleic acid systems is NP-hard. Despite this, multistranded and/or pseudoknotted systems represent some of the most utilised and successful systems in the field. This leaves open the tempting possibility that many of the kinds of multistranded and/or pseudoknotted systems we wish to engineer actually fall into restricted classes, that do in fact have polynomial time algorithms, but we've just not found them yet.  Here, we give polynomial time algorithms for MFE and partition function calculation for a restricted kind of multistranded system called the 1D scaffolded DNA computer. This model of computation thermodynamically favours correct outputs over erroneous states, simulates finite state machines in 1D and Boolean circuits in 2D, and is amenable to DNA storage applications. In an effort to begin to ask the question of whether we can naturally compare the expressivity of nucleic acid systems based on the computational complexity of prediction of their preferred energetic states, we show our MFE problem is in logspace (the complexity class L), making it perhaps one of the simplest known, natural, nucleic acid MFE problems. Finally, we provide a stochastic kinetic simulator for the 1D scaffolded DNA computer and evaluate strategies for efficiently speeding up this thermodynamically favourable system in a constant-temperature kinetic regime.},
  eventtitle = {29th {{International Conference}} on {{DNA Computing}} and {{Molecular Programming}} ({{DNA}} 29) (2023)},
  langid = {english},
  file = {/home/const/Zotero/storage/5EBN9C96/Shalaby et al. - 2023 - Minimum Free Energy, Partition Function and Kineti.pdf}
}

@article{she_comprehensive_2017,
  title = {Comprehensive and Quantitative Mapping of {{RNA}}–Protein Interactions across a Transcribed Eukaryotic Genome},
  author = {She, Richard and Chakravarty, Anupam K. and Layton, Curtis J. and Chircus, Lauren M. and Andreasson, Johan O. L. and Damaraju, Nandita and McMahon, Peter L. and Buenrostro, Jason D. and Jarosz, Daniel F. and Greenleaf, William J.},
  date = {2017-04-04},
