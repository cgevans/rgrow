@article{kim_nanoengineered_2024,
  title = {Nanoengineered {{Polymeric RNA Nanoparticles}} for {{Controlled Biodistribution}} and {{Efficient Targeted Cancer Therapy}}},
  author = {Kim, Taehyung and Han, Hwa Seung and Yang, Kyungjik and Kim, Young Min and Nam, Keonwook and Park, Kyung Hoon and Choi, Seung Young and Park, Hyun Woo and Choi, Ki Young and Roh, Young Hoon},
  date = {2024-03-19},
  journaltitle = {ACS Nano},
  shortjournal = {ACS Nano},
  volume = {18},
