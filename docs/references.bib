@online{ke_highthroughput_2024,
  title = {High-{{Throughput DNA}} Melt Measurements Enable Improved Models of {{DNA}} Folding Thermodynamics},
  author = {Ke, Yuxi and Sharma, Eesha and Wayment-Steele, Hannah K. and Becker, Winston R. and Ho, Anthony and Marklund, Emil and Greenleaf, William J.},
