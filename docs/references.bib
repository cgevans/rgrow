@article{bennett_logical_1973,
  title = {Logical {{Reversibility}} of {{Computation}}},
  author = {Bennett, C. H.},
  date = {1973-11},
  journaltitle = {IBM Journal of Research and Development},
  shortjournal = {IBM J. Res. \& Dev.},
  volume = {17},
  number = {6},
